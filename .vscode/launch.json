{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File (dmesh-sdk-docker)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/packages/dmesh-sdk/src;${workspaceFolder}/packages/dmesh-api/src;${workspaceFolder}/packages/dmesh-cli/src",
                "APP_ENV": "docker"
            }
        },
        {
            "name": "Python: Current File (dmesh-sdk-lakebase)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/packages/dmesh-sdk/src;${workspaceFolder}/packages/dmesh-api/src;${workspaceFolder}/packages/dmesh-cli/src",
                "APP_ENV": "my_lakebase"
            }
        }
    ]
}