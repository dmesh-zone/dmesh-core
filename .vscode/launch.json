{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Current Test File",
            "type": "debugpy",
            "request": "launch",
            "program": "${config:python.defaultInterpreterPath}",
            "args": [
                "-m",
                "pytest",
                "${file}",
                "-s"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/dmesh-cli",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dmesh-cli;${workspaceFolder}/dmesh-sdk/src"
            },
            "justMyCode": false
        },
        {
            "name": "Python: Debug All Integration Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration",
                "-s"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/dmesh-cli",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dmesh-cli;${workspaceFolder}/dmesh-sdk/src"
            },
            "justMyCode": false
        }
    ]
}