{
    "kiroAgent.configureMCP": "Disabled",
    "python.testing.pytestPath": "uv run pytest",
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.testing.promptToConfigure": false,
    "python.testing.cwd": "${workspaceFolder}",
    "python.testing.pytestArgs": [
        "tests"
    ],
    "python.testing.pytestEnvVars": {
        "VIRTUAL_ENV": "${workspaceFolder}/.venv"
    },
    "python.testing.debugJustMyCode": false,
    "python.analysis.extraPaths": [
        "${workspaceFolder}/packages/dmesh-sdk/src",
        "${workspaceFolder}/packages/dmesh-api/src",
        "${workspaceFolder}/packages/dmesh-cli/src"
    ],
    "python.autoComplete.extraPaths": [
        "${workspaceFolder}/packages/dmesh-sdk/src",
        "${workspaceFolder}/packages/dmesh-api/src",
        "${workspaceFolder}/packages/dmesh-cli/src"
    ]
}