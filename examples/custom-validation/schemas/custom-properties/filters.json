{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "properties": {
    "defaultBehavior": {
      "type": "string",
      "enum": [
        "noRowsReturned",
        "allRowsAndColumnsReturned"
      ],
      "default": "allRowsAndColumnsReturned"
    },
    "filterSelectExpressions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "expression": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "expression"
        ]
      }
    },
    "filterWhereExpressions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "expression": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "expression"
        ]
      }
    },
    "filterAssemblies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filterSelectExpression": {
            "type": "string"
          },
          "filterWhereExpression": {
            "type": "string"
          }
        },
        "required": [
          "users"
        ],
        "anyOf": [
          {
            "required": [
              "filterSelectExpression"
            ]
          },
          {
            "required": [
              "filterWhereExpression"
            ]
          }
        ]
      }
    },
    "environmentVariables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "var": {
            "type": "string"
          },
          "values": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "required": [
          "var",
          "values"
        ]
      }
    }
  },
  "required": [
    "defaultBehavior",
    "filterAssemblies",
    "environmentVariables"
  ],
  "anyOf": [
    {
      "required": [
        "filterSelectExpressions"
      ]
    },
    {
      "required": [
        "filterWhereExpressions"
      ]
    }
  ]
}