      "type": "string"
    },
    "targetTable": {
      "type": "string"
    },
    "sourceCatalog": {
      "type": "string"
    },
    "sourceSchema": {
      "type": "string"
    },
    "format": {
      "type": "string",
      "enum": [
        "deltaLake"
      ],
      "default": "deltaLake"
    },
    "s3Uri": {
      "type": "string"
    },
    "s3Region": {
