{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "properties": {
    "defaultBehavior": {
      "type": "string",
      "enum": ["noRowsReturned", "allRowsAndColumnsReturned"],
      "default": "allRowsAndColumnsReturned"
    },
    "filterSelectExpressions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "expression": { "type": "string" }
        },
        "required": ["name", "expression"]
      }
    },
    "filterAssemblies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": { "type": "string" }
          },
          "filterSelectExpressions": { "type": "string" }
        },
        "required": ["users", "filterSelectExpressions"]
      }
    },
    "environmentVariables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "var": { "type": "string" },
          "values": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        },
        "required": ["var", "values"]
      }
    }
  },
  "required": ["defaultBehavior", "filterSelectExpressions", "filterAssemblies", "environmentVariables"]
}
